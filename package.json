{
  "name": "cubric-vision",
  "version": "1.2.0",
  "description": "Cubric Vision Desktop app — Local Open Source Image and Video Generator",
  "main": "main.js",
  "productName": "Cubric Vision",
  "desktopName": "cubric-vision.desktop",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build:portable": "node scripts/build-portable.mjs",
    "build:portable:dry-run": "node scripts/build-portable.mjs --dry-run",
    "build:portable:win": "node scripts/build-portable.mjs --clean --platform win32 --arch x64 --stage-dir D:\\tmp\\cubric-portable --no-source-manifest",
    "build:portable:linux": "node scripts/build-portable.mjs --clean --platform linux --arch x64 --stage-dir D:\\tmp\\cubric-portable --no-source-manifest",
    "build:portable:mac": "node scripts/build-portable.mjs --clean --platform darwin --arch arm64 --stage-dir D:\\tmp\\cubric-portable --no-source-manifest",
    "release:check": "node scripts/release-health-check.mjs",
    "release:approve": "node scripts/release-notes-approval.mjs approve",
    "release:notes": "node scripts/release-notes-approval.mjs show",
    "test:desktop": "playwright test --config=playwright.desktop.config.js",
    "lint": "eslint js/ --max-warnings=9999",
    "lint:components": "eslint js/components/ --max-warnings=9999",
    "prepare": "husky"
  },
  "author": "MadPonyInteractive",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@cubric/connector": "file:../Cubric-Studio/packages/connector",
    "7zip-bin": "^5.2.0",
    "axios": "^1.13.6",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "electron-context-menu": "^4.1.2",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fs-extra": "^11.1.1",
    "mediabunny": "^1.50.8",
    "node-7z": "^3.0.0",
    "node-downloader-helper": "^2.1.11",
    "sharp": "^0.34.5",
    "trash": "^8.1.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "electron": "^41.0.3",
    "eslint": "^10.2.1",
    "firacode": "^6.2.0",
    "husky": "^9.1.7",
    "jetbrains-mono": "^1.0.6",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "js/**/*.js": [
      "eslint --no-error-on-unmatched-pattern --max-warnings=9999"
    ]
  }
}
